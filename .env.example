APP_NAME=WeatherEdge AI
ENVIRONMENT=development

DATABASE_URL=postgresql+psycopg2://weatheredge:weatheredge@localhost:5432/weatheredge

POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_ARCHIVE_BASE_URL=https://archive-api.open-meteo.com/v1
OPEN_METEO_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com/v1

# Optional observed-weather provider for manual backtest outcome resolution.
# Leave unset for local demos/tests unless explicitly exercising NOAA CDO.
NOAA_CDO_BASE_URL=https://www.ncei.noaa.gov/cdo-web/api/v2
# NOAA_CDO_TOKEN=

# Keep fixture geocoding for deterministic local demos/tests.
# Set to open_meteo to allow broader public geocoding during manual runs.
GEOCODING_PROVIDER=fixture

# Keep interval/range precipitation contracts out of the public paper runner
# unless manually opting in to the experimental interval baseline.
PAPER_RUNNER_ALLOW_INTERVAL_CONTRACTS=false

# Freshness guards for public paper-runner inputs. Set to 0 only for manual
# debugging when intentionally replaying old stored snapshots.
PAPER_RUNNER_MAX_PRICE_AGE_MINUTES=120
PAPER_RUNNER_MAX_FORECAST_AGE_HOURS=12

# Conservative paper portfolio limits for local research. These assume a small
# simulated bankroll and are not live-trading risk controls.
PAPER_RUNNER_MAX_OPEN_TRADES=5
PAPER_RUNNER_MAX_TOTAL_EXPOSURE=25
PAPER_RUNNER_MAX_MARKET_EXPOSURE=5
PAPER_RUNNER_MAX_LOCATION_EXPOSURE=10

# Optional paper fill realism. Zero keeps quoted price and fill price equal.
PAPER_RUNNER_ENTRY_SLIPPAGE_RATE=0

# Allow stale stored prices only when explicitly opting in to research-mode
# fallback after a public refresh failure.
PAPER_RUNNER_ALLOW_STALE_PRICE_FALLBACK=false

# Paper trading is the default. Live execution is blocked unless future
# execution code explicitly checks both settings and all safety controls.
TRADING_MODE=paper
LIVE_TRADING_ENABLED=false
